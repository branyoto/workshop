# CMS JSON URL served to the app.
# Local development: serve the seed file from Vite public assets.
VITE_CMS_URL=/cms.json

# Base URL for category and item thumbnail images (no trailing slash).
# Local development: serve images from Vite public assets.
VITE_CMS_IMAGE_BASE_URL=/images

# Production (jsDelivr CDN):
# VITE_CMS_URL=https://cdn.jsdelivr.net/gh/branyoto/workshop@main/public/cms.json
# VITE_CMS_IMAGE_BASE_URL=https://cdn.jsdelivr.net/gh/branyoto/workshop@main/public/images
